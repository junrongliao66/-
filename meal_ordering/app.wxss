page {
  background: #f3f4f6;
  color: #1f2937;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.card {
  margin: 24rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.desc {
  color: #6b7280;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.input,
.picker,
.textarea {
  width: 100%;
  min-height: 72rpx;
  box-sizing: border-box;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 28rpx;
  background: #fff;
}

.picker {
  display: flex;
  align-items: center;
  color: #111827;
}

.placeholder {
  color: #9ca3af;
}

.btn-primary {
  margin-top: 12rpx;
  background: #2563eb;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.empty {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 12rpx;
}

.table {
  width: 100%;
  border-top: 1rpx solid #e5e7eb;
}

.row {
  display: flex;
  border-bottom: 1rpx solid #e5e7eb;
}

.cell {
  flex: 1;
  padding: 12rpx 8rpx;
  font-size: 24rpx;
  word-break: break-all;
}

.head .cell {
  font-weight: 700;
  background: #f9fafb;
}
