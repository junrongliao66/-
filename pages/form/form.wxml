<view class="card">
  <view class="title">报餐申请表</view>
  <view class="desc">请填写姓名、日期、报餐时间段和报餐类型。</view>

  <view class="field">
    <text class="label">姓名</text>
    <input class="input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
  </view>

  <view class="field">
    <text class="label">日期</text>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="picker">{{date}}</view>
    </picker>
  </view>

  <view class="field">
    <text class="label">报餐时间段</text>
    <picker mode="selector" range="{{timeSlotOptions}}" value="{{timeSlotIndex}}" bindchange="onTimeSlotChange">
      <view class="picker {{timeSlotIndex < 0 ? 'placeholder' : ''}}">{{timeSlotIndex < 0 ? '请选择时间段' : timeSlotOptions[timeSlotIndex]}}</view>
    </picker>
  </view>

  <view class="field">
    <text class="label">报餐类型</text>
    <picker mode="selector" range="{{mealTypeOptions}}" value="{{mealTypeIndex}}" bindchange="onMealTypeChange">
      <view class="picker {{mealTypeIndex < 0 ? 'placeholder' : ''}}">{{mealTypeIndex < 0 ? '请选择报餐类型' : mealTypeOptions[mealTypeIndex]}}</view>
    </picker>
  </view>

  <view class="field">
    <text class="label">备注</text>
    <textarea class="textarea" placeholder="可填写特殊需求" value="{{remark}}" bindinput="onRemarkInput" />
  </view>

  <button class="btn-primary" bindtap="submitForm">提交报餐</button>
  <button bindtap="goAdmin">进入后台统计</button>
</view>
