<view class="card">
  <view class="title">每日报餐人员明细</view>
  <view class="field">
    <text class="label">查询日期</text>
    <picker mode="date" value="{{dailyDate}}" bindchange="onDailyDateChange">
      <view class="picker">{{dailyDate}}</view>
    </picker>
  </view>
  <button bindtap="queryDaily">查询</button>

  <view wx:if="{{dailyRecords.length}}" class="table">
    <view class="row head">
      <view class="cell">姓名</view>
      <view class="cell">时间段</view>
      <view class="cell">类型</view>
      <view class="cell">备注</view>
    </view>
    <view class="row" wx:for="{{dailyRecords}}" wx:key="id">
      <view class="cell">{{item.name}}</view>
      <view class="cell">{{item.timeSlot}}</view>
      <view class="cell">{{item.mealType}}</view>
      <view class="cell">{{item.remark || '-'}}</view>
    </view>
  </view>
  <view wx:else class="empty">该日期暂无报餐记录。</view>
</view>

<view class="card">
  <view class="title">每月人员报餐次数</view>
  <view class="field">
    <text class="label">查询月份</text>
    <picker mode="date" fields="month" value="{{month}}" bindchange="onMonthChange">
      <view class="picker">{{month}}</view>
    </picker>
  </view>
  <button bindtap="queryMonth">统计</button>

  <view wx:if="{{monthlyStats.length}}" class="table">
    <view class="row head">
      <view class="cell">姓名</view>
      <view class="cell">报餐次数</view>
    </view>
    <view class="row" wx:for="{{monthlyStats}}" wx:key="name">
      <view class="cell">{{item.name}}</view>
      <view class="cell">{{item.count}}</view>
    </view>
  </view>
  <view wx:else class="empty">该月份暂无报餐记录。</view>
</view>
